{
  "name": "goride-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node -e \"require('fs').closeSync(require('fs').openSync('prisma/dev.db','a'))\" && prisma migrate deploy",
    "prisma:push": "node -e \"require('fs').closeSync(require('fs').openSync('prisma/dev.db','a'))\" && prisma db push --skip-generate"
  },
  "dependencies": {
    "@prisma/client": "6.8.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.19",
    "prisma": "6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
